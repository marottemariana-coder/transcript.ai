# Copie para .env e preencha
DATABASE_URL=postgresql+psycopg://transcript:transcript@db:5432/transcript
REDIS_URL=redis://redis:6379/0
SECRET_KEY=troque-por-uma-chave-longa-aleatoria
MEDIA_DIR=/data/media

# Transcrição — provider padrão: "whisper" | "assemblyai"
TRANSCRIPTION_PROVIDER=whisper
OPENAI_API_KEY=
ASSEMBLYAI_API_KEY=

# Tradução — "deepl" | "llm" (usa Anthropic)
TRANSLATION_PROVIDER=deepl
DEEPL_API_KEY=
ANTHROPIC_API_KEY=

# Cotas (minutos/mês)
FREE_PLAN_MINUTES=120
ANON_MAX_MINUTES=15

# Download de redes sociais (Seção 3) — uso pessoal/interno
ENABLE_ORIGINAL_DOWNLOAD=true
# YouTube/Instagram/Facebook frequentemente exigem cookies de sessão
# (ex: YouTube pedindo "Sign in to confirm you're not a bot").
# Opção A — caminho de um arquivo cookies.txt já presente no disco:
YTDLP_COOKIES_FILE=
# Opção B — cole aqui o conteúdo do cookies.txt (formato Netscape),
# útil em plataformas sem disco persistente (ex: Railway). Só é usado
# se YTDLP_COOKIES_FILE estiver vazio.
YTDLP_COOKIES_CONTENT=
