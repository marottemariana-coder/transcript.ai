server {
    listen ${PORT};
    root /usr/share/nginx/html;
    index index.html;

    location /api/ {
        proxy_pass ${API_URL}/;
        # Sem "proxy_set_header Host $host": o roteamento de borda do Railway usa
        # o header Host para escolher o servico, e repassar o host do frontend
        # aqui faz requisicoes (principalmente POST) carem no lugar errado.
        # Sem essa linha, o nginx usa o host do proprio proxy_pass (o backend).
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri /index.html;
    }
}
